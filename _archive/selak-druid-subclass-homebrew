  .toc a:hover { color: var(--green-glow); }

  /* ── Main Layout ── */
  .page {
    max-width: 820px;
    margin: 0 auto;
    padding: 0 24px 80px;
  }

  /* ── Section Headers ── */
  .section-header {
    padding: 48px 0 12px;
    border-bottom: 1px solid var(--border-dark);
    margin-bottom: 24px;
  }

  .section-header h2 {
    font-family: 'Cinzel', serif;
    font-size: 1.6rem;
