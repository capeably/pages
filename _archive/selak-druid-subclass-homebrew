    vertical-align: top;
  }

  .ref-table td:first-child {
    font-family: 'Cinzel', serif;
    color: var(--accent-gold);
    font-weight: 600;
    white-space: nowrap;
  }

  .ref-table tr:last-child td { border-bottom: none; }

  /* ── Lore intro ── */
  .lore-intro {
    max-width: 720px;
    margin: 0 auto 12px;
    padding: 32px 0 24px;
    font-size: 1.05rem;
    color: var(--text-secondary);
    line-height: 1.85;
  }

  /* ── Divider ── */
  .divider {
