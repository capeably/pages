    --border-glow: #1a3d22;
    --accent-gold: #c4a35a;
    --accent-gold-dim: #8a7340;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  html {
    scroll-behavior: smooth;
  }

  body {
    font-family: 'Crimson Text', Georgia, serif;
    font-size: 17px;
    line-height: 1.7;
    color: var(--text-primary);
    background: var(--bg-dark);
    min-height: 100vh;
  }

  /* ── Hero ── */
  .hero {
    position: relative;
    text-align: center;
    padding: 80px 20px 60px;
    background: radial-gradient(ellipse at 50% 80%, rgba(30, 90, 40, 0.25) 0%, transparent 70%),
                var(--bg-dark);
    border-bottom: 1px solid var(--border-dark);
    overflow: hidden;
  }

  .hero::before {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    width: 300px;
    height: 300px;
    background: radial-gradient(circle, rgba(58, 255, 106, 0.08) 0%, transparent 70%);
    transform: translate(-50%, -40%);
    animation: pulse-glow 4s ease-in-out infinite;
  }

  @keyframes pulse-glow {
    0%, 100% { opacity: 0.5; transform: translate(-50%, -40%) scale(1); }
    50% { opacity: 1; transform: translate(-50%, -40%) scale(1.2); }
  }

  .hero-label {
    font-family: 'Cinzel', serif;
    font-size: 0.75rem;
    letter-spacing: 0.3em;
    text-transform: uppercase;
    color: var(--green-mid);
    margin-bottom: 12px;
    position: relative;
  }

  .hero h1 {
    font-family: 'Cinzel', serif;
    font-size: clamp(2.2rem, 5vw, 3.5rem);
    font-weight: 700;
    color: #e8f0ea;
    text-shadow: 0 0 40px rgba(58, 255, 106, 0.15);
    margin-bottom: 8px;
    position: relative;
  }

  .hero-sub {
    font-family: 'Cinzel', serif;
    font-size: 1rem;
    letter-spacing: 0.15em;
    color: var(--accent-gold);
    margin-bottom: 30px;
    position: relative;
  }

  .hero blockquote {
    max-width: 640px;
    margin: 0 auto;
    font-style: italic;
    color: var(--text-secondary);
    font-size: 1.05rem;
    line-height: 1.8;
    position: relative;
  }

  .hero blockquote cite {
    display: block;
    font-style: normal;
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-top: 8px;
  }

  /* ── Navigation ── */
  .toc {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: 6px 16px;
    padding: 16px 20px;
    background: var(--bg-section);
    border-bottom: 1px solid var(--border-dark);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .toc a {
    font-family: 'Cinzel', serif;
    font-size: 0.7rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text-muted);
    text-decoration: none;
    padding: 4px 8px;
    transition: color 0.3s;
