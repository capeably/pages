    margin: 16px 0 28px;
    font-size: 0.9rem;
  }

  .ref-table th {
    font-family: 'Cinzel', serif;
    font-size: 0.68rem;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--green-pale);
    text-align: left;
    padding: 8px 10px;
