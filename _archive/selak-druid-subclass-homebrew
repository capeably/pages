    border-bottom: 1px solid var(--border-dark);
    color: var(--text-primary);
  }

  .spell-table td:first-child {
    text-align: center;
    font-family: 'Cinzel', serif;
    color: var(--accent-gold);
    font-weight: 600;
  }

  .spell-table tr:last-child td { border-bottom: none; }

  /* ── Aspect Cards ── */
