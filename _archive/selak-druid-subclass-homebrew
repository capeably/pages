  .aspect-card-title h3 {
    font-family: 'Cinzel', serif;
    font-size: 1.35rem;
    font-weight: 600;
    color: #e0e8e2;
    margin-bottom: 2px;
  }

  .aspect-card-title .subtitle {
    font-family: 'Cinzel', serif;
    font-size: 0.75rem;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--accent-gold-dim);
  }

  .aspect-card-title .role-badge {
    display: inline-block;
    margin-top: 10px;
    font-family: 'Cinzel', serif;
    font-size: 0.65rem;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--green-mid);
    border: 1px solid var(--green-dim);
    padding: 3px 10px;
    border-radius: 2px;
  }

  .aspect-card-body {
    padding: 20px 28px 24px;
    border-top: 1px solid var(--border-dark);
  }

  .aspect-card-body .flavor {
    font-size: 0.92rem;
    margin-bottom: 16px;
  }

  /* ── Feature Bullets ── */
  .feature-item {
    margin-bottom: 12px;
    padding-left: 0;
  }

  .feature-item .fname {
    font-weight: 700;
